# 数据库路径（默认：data/matrix_etf.db）
DB_PATH=data/matrix_etf.db

# 数据起始日期（默认：2020-01-01），用于全量回填
START_DATE=2020-01-01

# tickflow API Key（可选）。
#   留空 → 使用免费服务 TickFlow.free()（历史日 K + 标的信息，足够日常选 ETF）
#   非空 → 使用完整服务 TickFlow(api_key=...)（实时/分钟线）
TICKFLOW_API_KEY=

# tickflow ETF 标的池 id（默认：CN_ETF）
ETF_UNIVERSE=CN_ETF

# ── 股票（A 股）线（可选，与 ETF 线完全解耦）──
# 股票 SQLite 路径（默认：data/matrix_stock.db），独立于 ETF 数据库
STOCK_DB_PATH=data/matrix_stock.db
# tickflow A 股标的池 id（默认：CN_Equity_A，约 5500 只全 A 股）
STOCK_UNIVERSE=CN_Equity_A

# ── 策略参数（可选，均有默认值）──
# 流动性门槛：近 20 日平均成交额下限（元），默认 5000 万
LIQUIDITY_MIN_AMOUNT=50000000
# 动量/RPS 回看天数，默认 120
RPS_PERIOD=120
# RPS 百分位阈值（0~100），默认 90
RPS_THRESHOLD=90
# 突破策略回看天数，默认 60
BREAKOUT_PERIOD=60
# 放量倍数，默认 1.5
VOLUME_SURGE=1.5

# ── 股票策略参数（可选，均有默认值）──
# 股票流动性门槛：当日成交额下限（元），默认 1 亿
STOCK_LIQUIDITY_MIN_AMOUNT=100000000
# 股票均线放量策略的放量倍数，默认 1.5
STOCK_MA_VOLUME_SURGE=1.5
# 股票 RPS 回看天数，默认 120
STOCK_RPS_PERIOD=120
# 股票 RPS 百分位阈值（0~100），默认 90
STOCK_RPS_THRESHOLD=90

# Mega7 风格轮动参数（日线交易日数，默认近 1/3/6 个月）
MEGA7_MOMENTUM_PERIODS=21,63,126
MEGA7_VOLATILITY_DAYS=21
MEGA7_TOP_N=10
MEGA7_DOWNSIDE_LOOKBACK_DAYS=63
MEGA7_DOWNSIDE_THRESHOLD=0.5
MEGA7_VOLUME_SHORT_DAYS=21
MEGA7_VOLUME_LONG_DAYS=63
MEGA7_VOLUME_MULTIPLIER_FLOOR=0.5
MEGA7_VOLUME_MULTIPLIER_CAP=2.0

# 日常模式交易日保护：周末自动跳过；A 股节假日可用逗号配置
SKIP_NON_TRADING_DAY=true
CN_MARKET_HOLIDAYS=

# 默认飞书 Webhook URL（必填，作为 fallback）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-default-token
FEISHU_TIMEOUT_SECONDS=10
FEISHU_RETRY_ATTEMPTS=3
FEISHU_RETRY_BACKOFF_SECONDS=1

# 策略专属 Webhook（可选，格式：STRATEGY_WEBHOOK_<策略标识>=<URL>）
# 未配置的策略将自动使用默认 FEISHU_WEBHOOK_URL
STRATEGY_WEBHOOK_RPS=https://open.feishu.cn/open-apis/bot/v2/hook/your-rps-token
STRATEGY_WEBHOOK_TREND=https://open.feishu.cn/open-apis/bot/v2/hook/your-trend-token
STRATEGY_WEBHOOK_BREAKOUT=https://open.feishu.cn/open-apis/bot/v2/hook/your-breakout-token
STRATEGY_WEBHOOK_PULLBACK=https://open.feishu.cn/open-apis/bot/v2/hook/your-pullback-token
STRATEGY_WEBHOOK_MEGA7_MOMENTUM=https://open.feishu.cn/open-apis/bot/v2/hook/your-mega7-momentum-token
STRATEGY_WEBHOOK_MEGA7_VOLUME=https://open.feishu.cn/open-apis/bot/v2/hook/your-mega7-volume-token
STRATEGY_WEBHOOK_MEGA7_LOWVOL=https://open.feishu.cn/open-apis/bot/v2/hook/your-mega7-lowvol-token

# 股票策略专属 Webhook（可选，均带 STOCK_ 前缀，与 ETF 推送解耦）
STRATEGY_WEBHOOK_STOCK_MA_VOLUME=https://open.feishu.cn/open-apis/bot/v2/hook/your-stock-ma-volume-token
STRATEGY_WEBHOOK_STOCK_TURTLE=https://open.feishu.cn/open-apis/bot/v2/hook/your-stock-turtle-token
STRATEGY_WEBHOOK_STOCK_FLAG=https://open.feishu.cn/open-apis/bot/v2/hook/your-stock-flag-token
STRATEGY_WEBHOOK_STOCK_SHAKEOUT=https://open.feishu.cn/open-apis/bot/v2/hook/your-stock-shakeout-token
STRATEGY_WEBHOOK_STOCK_LIMIT_DOWN=https://open.feishu.cn/open-apis/bot/v2/hook/your-stock-limit-down-token
STRATEGY_WEBHOOK_STOCK_RPS=https://open.feishu.cn/open-apis/bot/v2/hook/your-stock-rps-token
